{
  "layer": "top",
  "output": [
    "DP-1",
    "DP-2",
    "DP-3"
  ],
  "bar_id": "bar-external",
  "height": 20,
  "ipc": true,
  "position": "top",
  "modules-left": [
    "hyprland/workspaces",
    "custom/touch_menu",
    "idle_inhibitor"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "pulseaudio",
    "battery",
    "network",
    "cpu",
    "memory",
    "tray"
  ],
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "",
      "deactivated": ""
    }
  },
  "hyprland/workspaces": {
    "format": "{name}: {icon}",
    "all-outputs": false,
    "format-icons": {
      "active": "",
      "default": ""
    }
  },
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },
  "clock": {
    "timezone": "Europe/Berlin",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    // "format": "{:%d - %H:%M}"
    "format": "{:%Y-%m-%d %H:%M}",
    "format-alt": "{:%Y-%m-%d}"
  },
  "network": {
    "format-wifi": "󰤢 ",
    "format-ethernet": "󰈀 ",
    "format-disconnected": "󰤠 ",
    "interval": 5,
    "tooltip": false
  },
  "cpu": {
    "interval": 1,
    "format": "  {icon0}{icon1}{icon2}{icon3} {usage:>2}%",
    "format-icons": [
      "▁",
      "▂",
      "▃",
      "▄",
      "▅",
      "▆",
      "▇",
      "█"
    ]
  },
  "memory": {
    "interval": 30,
    // "format": "  {used:0.1f}G/{total:0.1f}G",
    "format": "{}% "
  },
  "pulseaudio": {
    "format": "{volume}% {icon} {format_source}",
    "format-bluetooth": "{volume}% {icon} {format_source}",
    "format-muted": " {format_source}",
    "format-source": "{volume}% ",
    "format-source-muted": "",
    "format-icons": {
      "headphones": "",
      "handsfree": "",
      "headset": "",
      "phone": "",
      "portable": "",
      "car": "",
      "default": [
        "",
        "",
        ""
      ]
    },
    "on-click": "pavucontrol"
  },
  "custom/lock": {
    "tooltip": false,
    //"on-click": "sh -c hypr-lock & disown",
    "on-click": "wlogout",
    "format": "🔐"
  },
  "later": {
    "format": "<span class='icon'>{icon}</span> <span class='text'>{text}</span>"
  },
  "custom/touch_menu": {
    "tooltip": false,
    "format": "󰀻",
    "on-click": "hypr-touch-menu"
  },
  "custom/screen_toggle": {
    "format": "💻",
    "on-click": "hypr-profile"
  },
  "battery": {
    "bat": "BAT0",
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% ",
    "format-plugged": "{capacity}% ",
    "format-alt": "{time} {icon}",
    "format-full": "",
    "format-icons": [
      "",
      "",
      "",
      "",
      ""
    ]
  },
}
