{
  "layer": "top",
  "output": "eDP-2",
  "bar_id": "bar-1",
  "height": 20,
  "ipc": true,
  "position": "top",
  "modules-left": [
    "hyprland/workspaces",
    "custom/touch_menu",
    "idle_inhibitor"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "pulseaudio",
    "battery",
    "network",
    "cpu",
    "memory",
    "tray"
  ],
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "яБо",
      "deactivated": "яБ░"
    }
  },
  "hyprland/workspaces": {
    "format": "{name}: {icon}",
    "all-outputs": false,
    "format-icons": {
      "active": "яЖТ",
      "default": "яДС"
    }
  },
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },
  "clock": {
    "timezone": "Europe/Berlin",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    // "format": "{:%d - %H:%M}"
    "format": "{:%Y-%m-%d %H:%M}",
    "format-alt": "{:%Y-%m-%d}"
  },
  "network": {
    "format-wifi": "ґ░дв ",
    "format-ethernet": "ґ░ИА ",
    "format-disconnected": "ґ░да ",
    "interval": 5,
    "tooltip": false
  },
  "cpu": {
    "interval": 1,
    "format": "яЛЫ  {icon0}{icon1}{icon2}{icon3} {usage:>2}%",
    "format-icons": [
      "тЦБ",
      "тЦВ",
      "тЦГ",
      "тЦД",
      "тЦЕ",
      "тЦЖ",
      "тЦЗ",
      "тЦИ"
    ]
  },
  "memory": {
    "interval": 30,
    // "format": "ю┐Е  {used:0.1f}G/{total:0.1f}G",
    "format": "{}% яГЙ"
  },
  "pulseaudio": {
    "format": "{volume}% {icon} {format_source}",
    "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
    "format-muted": "яЪй {format_source}",
    "format-source": "{volume}% яД░",
    "format-source-muted": "яД▒",
    "format-icons": {
      "headphones": "яАе",
      "handsfree": "яЦР",
      "headset": "яЦР",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": [
        "яАж",
        "яАз",
        "яАи"
      ]
    },
    "on-click": "pavucontrol"
  },
  "custom/lock": {
    "tooltip": false,
    //"on-click": "sh -c hyprlock & disown",
    "on-click": "wlogout",
    "format": "ЁЯФР"
  },
  "later": {
    "format": "<span class='icon'>{icon}</span> <span class='text'>{text}</span>"
  },
  "custom/touch_menu": {
    "tooltip": false,
    "format": "ґ░А╗",
    "on-click": "hypr-touch-menu"
  },
  "custom/screen_toggle": {
    "tooltip": false,
    "format": "ЁЯТ╗",
    "on-click": "hypr-profile"
  },
  "custom/rotation": {
    "tooltip": false,
    "on-click": "hypr-iio-toggle",
    "format": "ЁЯФД"
  },
  "battery": {
    "bat": "BAT0",
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% яЧз",
    "format-plugged": "{capacity}% яЗж",
    "format-alt": "{time} {icon}",
    "format-full": "",
    "format-icons": [
      "яЙД",
      "яЙГ",
      "яЙВ",
      "яЙБ",
      "яЙА"
    ]
  },
}
