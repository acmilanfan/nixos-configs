{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
    ],
    "modules-right": [
        "custom/layout",
        "custom/power",
        "custom/timer",
        "custom/ai_agents",
        "custom/window_toggle",
        "custom/touch_toggle",
        "custom/screen_toggle",
        "idle_inhibitor",
        "cpu",
        "memory",
        "battery",
        "pulseaudio",
        "tray",
        "clock"
    ],
    "custom/layout": {
        "format": "{}",
        "interval": 2,
        "return-type": "json",
        "exec": "hypr-layout-status"
    },
    "custom/power": {
        "format": "{}",
        "interval": 30,
        "return-type": "json",
        "exec": "hypr-power-watts"
    },
    "custom/timer": {
        "format": "{}",
        "interval": 1,
        "return-type": "json",
        "exec": "hypr-timer output",
        "on-click": "hypr-timer stop",
        "on-click-right": "hypr-timer reset",
        "on-click-middle": "hypr-timer start 25",
        "tooltip": true
    },
    "custom/ai_agents": {
        "format": "{}",
        "interval": 10,
        "return-type": "json",
        "exec": "hypr-ai-agents",
        "on-click": "hypr-ai-agents --menu",
        "tooltip": true
    },
    "hyprland/workspaces": {
        "format": "{id}",
        "persistent-workspaces": {
            "*": 10
        }
    },
    "clock": {
        "format": "{:%Y-%m-%d %H:%M}",
        "tooltip": true
    },
    "battery": {
        "format": "{capacity}% {icon}",
        "format-icons": [
            "",
            "",
            "",
            "",
            ""
        ]
    },
    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-muted": "",
        "format-icons": {
            "default": [
                "",
                ""
            ]
        }
    },
    "custom/screen_toggle": {
        "format": "🖥",
        "on-click": "screen-toggle-hypr"
    },
    "custom/touch_toggle": {
        "format": "✋",
        "on-click": "touch-toggle-hypr"
    },
    "custom/window_toggle": {
        "format": "🪟",
        "on-click": "hyprctl dispatch togglegroup"
    }
}
