#!/usr/bin/env bash
# Fuzzy-pick a git worktree.
# No flags  : prints selected path to stdout (ZSH widget cds to it)
# --tmux    : create/switch a tmux session for the selected worktree
# --claude  : like --tmux but also starts `claude` in the new session
# --gemini  : like --tmux but also starts `gemini` in the new session

selected=$(git worktree list --porcelain 2>/dev/null \
  | awk '/^worktree / {print $2}' \
  | fzf --prompt="Worktree > " \
        --preview="git -C {} log --oneline --color=always -10 2>/dev/null; echo; ls {}" \
        --height=50%)

[[ -z "$selected" ]] && exit 0

_tmux_switch() {
  local path="$1" cmd="$2"
  local name
  name=$(basename "$path" | tr '.' '_')
  if ! tmux has-session -t="$name" 2>/dev/null; then
    tmux new-session -ds "$name" -c "$path"
  fi
  tmux switch-client -t "$name"
  [[ -n "$cmd" ]] && tmux send-keys -t "$name" "$cmd" Enter
}

case "$1" in
  --claude) _tmux_switch "$selected" "claude" ;;
  --gemini) _tmux_switch "$selected" "gemini" ;;
  --tmux)   _tmux_switch "$selected" "" ;;
  *)        echo "$selected" ;;
esac
