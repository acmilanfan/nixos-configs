#!/usr/bin/env bash

# Main menu items
choice=$(echo -e "рџљЂ Apps\nрџ’» Profiles\nрџ”„ Auto-rotate: $(systemctl --user is-active hypr-iio-rotate.service >/dev/null && echo "ON" || echo "OFF")\nрџ“Љ Waybar Toggle\nвЊЁпёЏ Keyboard\nрџ“¶ Network\nпЉ” Bluetooth\nрџ’Ў Brightness\nрџ”Љ Volume\nрџ”’ Power" | \
    fuzzel --dmenu --prompt "Touch Menu: ")

case "$choice" in
    "рџљЂ Apps")
        nwg-drawer
        ;;
    "рџ’» Profiles")
        hypr-profile
        ;;
    "рџ”„ Auto-rotate"*)
        hypr-iio-toggle
        ;;
    "рџ“Љ Waybar Toggle")
        hypr-waybar-toggle
        ;;
    "вЊЁпёЏ Keyboard")
        hypr-toggle-kb
        ;;
    "рџ“¶ Network")
        iwmenu -l fuzzel
        ;;
    "пЉ” Bluetooth")
        bzmenu -l fuzzel
        ;;
    "рџ’Ў Brightness")
        val=$(echo -e "100%\n80%\n60%\n40%\n20%\n5%" | fuzzel --dmenu --prompt "Brightness: ")
        if [[ -n "$val" ]]; then
            # Remove % for set-sync-brightness
            clean_val="${val%%%}"
            if command -v set-sync-brightness >/dev/null; then
                set-sync-brightness "$clean_val"
            else
                brightnessctl set "$val"
            fi
        fi
        ;;
    "рџ”Љ Volume")
        val=$(echo -e "100%\n80%\n60%\n40%\n20%\n0%" | fuzzel --dmenu --prompt "Volume: ")
        if [[ -n "$val" ]]; then
             # Remove % for change-volume
             clean_val="${val%%%}"
             if command -v change-volume >/dev/null; then
                change-volume "$clean_val"
            else
                pamixer --set-volume "$clean_val"
            fi
        fi
        ;;
    "рџ”’ Power")
        wlogout
        ;;
esac
